{
    "name": "ati/api-email-lib",
    "description": "Laravel mail driver para envio via API HTTP customizada",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "barbosalucas",
            "email": "barbosalucaslbs96@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "symfony/mailer": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Ati\\ApiEmailLib\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ati\\ApiEmailLib\\AtiEmailServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
