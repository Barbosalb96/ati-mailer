# -------------------------------------------------------
# Driver de e-mail: aponta para o driver registrado pelo pacote
# -------------------------------------------------------
MAIL_MAILER=ati

# Remetente padrão (configuração nativa do Laravel)
MAIL_FROM_ADDRESS="noreply@seudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# Credenciais da API de e-mail (lidas por config/meu-servico.php)
# -------------------------------------------------------
ATI_EMAIL_KEY=sua_api_key_aqui
ATI_EMAIL_ENDPOINT=https://api.seuservico.com/v1/send
