# -------------------------------------------------------
# Driver de e-mail: aponta para o driver registrado pelo pacote
# -------------------------------------------------------
MAIL_MAILER=ati

# Remetente padrão (configuração nativa do Laravel)
MAIL_FROM_ADDRESS="noreply@seudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# Credenciais da API de e-mail (lidas por config/ati-servico.php)
# -------------------------------------------------------
ATI_EMAIL_KEY=sua_api_key_aqui

# URL base da API (sem caminho). Ex: https://api.seuservico.com
ATI_EMAIL_ENDPOINT=https://api.seuservico.com

# Modo staging: true = teste, false = produção
ATI_STAGING=true

# Certificado SSL: true (padrão do sistema), false (desabilitado) ou caminho para .pem
ATI_SSL_CERT=false

# Timeout em segundos para chamadas à API
ATI_EMAIL_TIMEOUT=30
